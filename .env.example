# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ── Сервер ────────────────────────────────────────────────────────
PORT=5000

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=замените-на-длинный-случайный-секрет

# ── PostgreSQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=himia_db

# ── Фронтенд ─────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000
